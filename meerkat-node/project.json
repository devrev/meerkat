{
  "name": "meerkat-node",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "meerkat-node/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/js:swc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/meerkat-node",
        "main": "meerkat-node/src/index.ts",
        "tsConfig": "meerkat-node/tsconfig.lib.json",
        "assets": ["meerkat-node/*.md"]
      }
    },
    "publish": {
      "command": "node tools/scripts/publish.mjs meerkat-node {args.ver} {args.tag}",
      "dependsOn": ["build"]
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": [
          "meerkat-node/**/*.ts",
          "meerkat-node/package.json"
        ]
      }
    },
    "test": {
      "executor": "@nx/vitest:test",
      "options": {
        "configFile": "meerkat-node/vitest.config.ts",
        "passWithNoTests": true,
        "reportsDirectory": "../coverage/meerkat-node"
      },
      "configurations": {
        "ci": {
          "mode": "ci"
        }
      }
    }
  }
}
