{
  "name": "meerkat-node",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "meerkat-node/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nx/js:swc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/meerkat-node",
        "main": "meerkat-node/src/index.ts",
        "tsConfig": "meerkat-node/tsconfig.lib.json",
        "assets": ["meerkat-node/*.md"]
      }
    },
    "publish": {
      "command": "node tools/scripts/publish.mjs meerkat-node {args.ver} {args.tag}",
      "dependsOn": ["build"]
    },
    "lint": {
      "executor": "@nx/linter:eslint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": [
          "meerkat-node/**/*.ts",
          "meerkat-node/package.json"
        ]
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "outputs": [
        "{workspaceRoot}/coverage/meerkat-node"
      ],
      "options": {
        "command": "npx vitest run --config meerkat-node/vitest.config.ts"
      }
    }
  },
  "tags": []
}
